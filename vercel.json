{
    "builds": [
        {
            "src": "api/webhook.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/webhook.py"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 5-23,0 * * *"
        }
    ]
}